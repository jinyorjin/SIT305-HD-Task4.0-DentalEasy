<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_surface"
    android:elevation="1dp"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvHistoryType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type"
        android:textColor="#1976D2"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistoryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Title"
        android:textColor="#1F2D3D"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistoryDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Description preview"
        android:textColor="#425466"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvHistoryTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="2026-04-27 20:00"
        android:textColor="#6B7280"
        android:textSize="12sp" />

</LinearLayout>
