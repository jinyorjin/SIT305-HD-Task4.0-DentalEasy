<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFF"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Initial Disclaimer -->
        <TextView
            android:id="@+id/tvDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:padding="14dp"
            android:text="This app provides general dental information only."
            android:textColor="#1565C0"
            android:textSize="12sp"
            tools:text="Disclaimer test" />

        <!-- A. Top Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DentalEasy"
                android:textColor="#1F2D3D"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Your AI Dental Guide"
                android:textColor="#5F6C7B"
                android:textSize="14sp" />

            <!-- B. Search Bar as white pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_surface"
                android:orientation="horizontal"
                android:padding="6dp"
                android:elevation="1dp">

                <EditText
                    android:id="@+id/etDentalTerm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Enter dental terms"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="#212121"
                    android:textColorHint="#9E9E9E"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnAnalyze"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#1976D2"
                    android:text="Search"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <Button
                android:id="@+id/btnViewHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button"
                android:text="View History"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Dental Chart"
                android:textColor="#1F2D3D"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tap a tooth to view basic information"
                android:textColor="#5F6C7B"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnToggleDentalChart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button"
                android:text="Open Dental Chart"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null" />

            <LinearLayout
                android:id="@+id/chartExpandableContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_surface"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Dental chart image"
                        android:scaleType="fitCenter"
                        android:src="@drawable/dental_chart" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_surface"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select a tooth"
                    android:textColor="#1F2D3D"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp"
                    android:text="Upper Right"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <Button android:id="@+id/btnTooth17" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth16" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth15" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth14" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth13" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth12" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth11" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp"
                    android:text="Upper Left"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <Button android:id="@+id/btnTooth21" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth22" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth23" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth24" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth25" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth26" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth27" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp"
                    android:text="Lower Left"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <Button android:id="@+id/btnTooth37" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth36" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth35" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth34" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth33" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth32" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth31" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp"
                    android:text="Lower Right"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <Button android:id="@+id/btnTooth41" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth42" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth43" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth44" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth45" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth46" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                    <Button android:id="@+id/btnTooth47" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_tooth_button" android:backgroundTint="@null" app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_info"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected Tooth"
                    android:textColor="#1F2D3D"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvToothInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tap a tooth to see information."
                    android:textColor="#425466"
                    android:textSize="14sp"
                    tools:text="Tooth 11: Upper right central incisor. Used for biting and appearance." />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Loading Message -->
            <TextView
                android:id="@+id/tvLoadingMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="Analyzing dental term..."
                android:textColor="#1976D2"
                android:textSize="14sp"
                android:textStyle="italic"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- E. Result Section (MOST IMPORTANT) -->
            <LinearLayout
                android:id="@+id/llResultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- 2. Emergency UI Title -->
                <TextView
                    android:id="@+id/tvEmergencyTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Emergency Warning"
                    android:textColor="#C62828"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Simplified Explanation"
                    android:textColor="#1976D2"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="What is it?"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvExplanation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    tools:text="Simple text explanation will appear here." />

                <TextView
                    android:id="@+id/tvUsuallyMeansTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Why is it needed &amp; How it works"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUsuallyMeans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    tools:text="Context regarding the diagnosis." />

                <TextView
                    android:id="@+id/tvAfterCareTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Care Tips"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAfterCare"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    tools:text="Take pain relief." />

                <!-- F. Rounded Blue Button -->
                <Button
                    android:id="@+id/btnPostCare"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button"
                    android:text="View Post-treatment Care"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <!-- C. Categories Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Categories"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card 1 -->
                <LinearLayout
                    android:id="@+id/cardGeneralDentistry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General Dentistry"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Checkups, fillings, and routine cleanings."
                        android:textColor="#616161"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Card 2 -->
                <LinearLayout
                    android:id="@+id/cardOrthodontics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orthodontics"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Braces, clear aligners, and bite correction."
                        android:textColor="#616161"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Card 3 -->
                <LinearLayout
                    android:id="@+id/cardDentalImplants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dental Implants"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Permanent tooth replacements and grafts."
                        android:textColor="#616161"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- D. Quick AI Summary Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="Quick AI Examples"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExampleTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Privacy Notice -->
            <TextView
                android:id="@+id/tvPrivacyNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                tools:text="Privacy Note" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>